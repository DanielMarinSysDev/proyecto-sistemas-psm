# ===================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - TASKCORE
# ===================================================================

# Configuración de Base de Datos PostgreSQL
DB_NAME=sistema_taskcore
DB_USER=taskcore_user
DB_PASSWORD=taskcore_pass_123
DB_HOST=db
DB_PORT=5432

# URL de Conexión de SQLAlchemy (usar localhost si se ejecuta fuera de Docker)
DATABASE_URL=postgresql://taskcore_user:taskcore_pass_123@db:5432/sistema_taskcore

# Puerto expuesto para el servidor web y base de datos
WEB_PORT_HOST=80
DB_PORT_HOST=5432

# Ruta de almacenamiento de archivos y activos del sistema
# Local: ./TaskCore_Archivos
# Docker: /app/TaskCore_Archivos
BASE_DIR=./TaskCore_Archivos
BASE_DIR_HOST=./TaskCore_Archivos
DB_DATA_DIR=./db_data

# Clave secreta para manejo de sesiones en Flask
SECRET_KEY=clave_secreta_segura_de_taskcore_para_produccion
